pipeline {
    agent any

    stages {

        stage('Build Info') {
            steps {
                script {
                    currentBuild.displayName = "#${env.BUILD_NUMBER}"
                    currentBuild.description = "DEV Deployment Started"
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('employee-management-app') {
                    bat 'npm install'
                }
            }
        }

        stage('Lint') {
            steps {
                dir('employee-management-app') {
                    bat 'npm run lint'
                }
            }
        }

        stage('Build DEV Artifact') {
            steps {
                dir('employee-management-app') {
                    bat 'npm run build -- --configuration=development --base-href=/employee-app-dev/'
                }
            }
        }

        stage('Archive Artifact') {
            steps {
                archiveArtifacts(
                    artifacts: 'employee-management-app/dist/**/*',
                    fingerprint: true,
                    allowEmptyArchive: true
                )
            }
        }

        stage('Deploy DEV') {
            steps {

                bat '''
                if exist "E:\\xampp8\\htdocs\\employee-app-dev" rmdir /S /Q "E:\\xampp8\\htdocs\\employee-app-dev"
                mkdir "E:\\xampp8\\htdocs\\employee-app-dev"

                xcopy /E /Y /I employee-management-app\\dist\\employee-management-app\\browser "E:\\xampp8\\htdocs\\employee-app-dev"
                '''

                script {
                    currentBuild.description = "DEV ✓"
                }

                echo 'DEV Deployment Successful'
            }
        }

        stage('Verify Deployment') {
            steps {
                echo 'DEV URL : http://localhost/employee-app-dev/'
            }
        }
    }

    post {

        success {
            script {
                currentBuild.description = "DEV ✓ | SUCCESS"
            }

            echo "Build #${env.BUILD_NUMBER} SUCCESS"
        }

        failure {
            script {
                currentBuild.description = "FAILED"
            }

            echo "Build #${env.BUILD_NUMBER} FAILED"
        }

        always {
            cleanWs()
        }
    }
}