pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                dir('employee-management-app') {
                    bat 'npm install'
                }
            }
        }

        stage('Build Angular App') {
            steps {
                dir('employee-management-app') {
                    bat 'npm run build'
                }
            }
        }
    }

    post {
        success {
            archiveArtifacts artifacts: 'employee-management-app/dist/**/*'
            echo 'Build completed successfully'
        }

        failure {
            echo 'Build failed'
        }
    }
}