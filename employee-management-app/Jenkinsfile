pipeline {
    agent any

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['DEV', 'TESTING', 'PROD'],
            description: 'Select deployment environment'
        )
    }

    stages {

        stage('Install Dependencies') {
            steps {
                dir('employee-management-app') {
                    bat 'npm install'
                }
            }
        }

        stage('Lint') {
            steps {
                dir('employee-management-app') {
                    bat 'npm run lint'
                }
            }
        }

        stage('Test') {
            steps {
                dir('employee-management-app') {
                    bat 'npm test -- --watch=false'
                }
            }
        }

        stage('Build') {
            steps {
                dir('employee-management-app') {
                    script {

                        def buildConfig = "development"

                        if (params.ENVIRONMENT == "TESTING") {
                            buildConfig = "testing"
                        }

                        if (params.ENVIRONMENT == "PROD") {
                            buildConfig = "production"
                        }

                        echo "Building for ${params.ENVIRONMENT}"
                        bat "npm run build -- --configuration=${buildConfig}"
                    }
                }
            }
        }

     stage('Deploy') {
    steps {
        script {

            def targetPath = "E:\\cicd\\Deployments\\DEV"

            if (params.ENVIRONMENT == 'TESTING') {
                targetPath = "E:\\cicd\\Deployments\\TESTING"
            }

            if (params.ENVIRONMENT == 'PROD') {
                targetPath = "E:\\cicd\\Deployments\\PROD"
            }

            bat """
            if exist "${targetPath}" rmdir /S /Q "${targetPath}"
            mkdir "${targetPath}"

            xcopy /E /Y /I employee-management-app\\dist\\employee-management-app "${targetPath}"
            """

            echo "Deployed to ${params.ENVIRONMENT}"
        }
    }
}
    }

    post {

        success {
            archiveArtifacts artifacts: 'employee-management-app/dist/**/*'
            echo "Build completed successfully for ${params.ENVIRONMENT}"
        }

        failure {
            echo "Build failed for ${params.ENVIRONMENT}"
        }
    }
} 