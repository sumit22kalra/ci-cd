pipeline {
    agent any

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['DEV', 'TESTING', 'PROD'],
            description: 'Select deployment environment'
        )
    }

    stages {

        stage('Install Dependencies') {
            steps {
                dir('employee-management-app') {
                    bat 'npm install'
                }
            }
        }

        stage('Lint') {
            steps {
                dir('employee-management-app') {
                    bat 'npm run lint'
                }
            }
        }

        stage('Test') {
            steps {
                dir('employee-management-app') {
                    bat 'npm test -- --watch=false'
                }
            }
        }

        stage('Build') {
            steps {
                dir('employee-management-app') {
                    script {

                        def buildConfig = "development"

                        if (params.ENVIRONMENT == "TESTING") {
                            buildConfig = "testing"
                        }

                        if (params.ENVIRONMENT == "PROD") {
                            buildConfig = "production"
                        }

                        echo "Building for ${params.ENVIRONMENT}"
                        bat "npm run build -- --configuration=${buildConfig}"
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                script {

                    if (params.ENVIRONMENT == "DEV") {
                        echo "Deploying to DEV Environment"
                    }

                    if (params.ENVIRONMENT == "TESTING") {
                        echo "Deploying to TESTING Environment"
                    }

                    if (params.ENVIRONMENT == "PROD") {
                        echo "Deploying to PROD Environment"
                    }
                }
            }
        }
    }

    post {

        success {
            archiveArtifacts artifacts: 'employee-management-app/dist/**/*'
            echo "Build completed successfully for ${params.ENVIRONMENT}"
        }

        failure {
            echo "Build failed for ${params.ENVIRONMENT}"
        }
    }
}